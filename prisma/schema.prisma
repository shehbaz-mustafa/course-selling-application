// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String @id @default(uuid())
  email     String @unique
  password  String
  firstName String
  lastName  String
}

model Admin {
  id        String @id @default(uuid())
  email     String @unique
  password  String
  firstName String
  lastName  String
}

model Course {
  id          String @id @default(uuid())
  title       String
  description String
  price       Float
  imageUrl    String
  creatorId   String
}

model Purchase {
  id       String @id @default(uuid())
  userId   String
  courseId String
}
